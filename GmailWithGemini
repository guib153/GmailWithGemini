/**
 * 1. autoOrganizeGmailWithGemini()
 *    - 說明：智慧郵件分類主程式。
 *    - 用途：掃描未讀信件，進行 AI 語意類別/緊急度判讀、自動精煉 20 字重點、貼上 Gmail 自訂標籤、移往對應 Gmail 收件匣分頁，並在試算表寫入日誌記錄。
 *    - 使用方式：可手動單次點擊「執行」進行測試，或是設定為「時間驅動」的定時觸發條件（如每 10 分鐘或每小時自動運行）。
 * 
 * 2. syncExistingLabeledThreadsToCategories()
 *    - 說明：歷史信件收件匣分頁一鍵同步工具。
 *    - 用途：掃描您收件匣中所有「過去已被貼上 AI/工作、AI/社群通知 等自訂標籤」的舊信件，直接調用 API 把對應的 Gmail 系統分頁標籤補上去。
 *    - 使用方式：當您首次啟用收件匣分頁歸類功能時，手動點擊執行此函式一次。此操作完全是讀取現有自訂標籤，100% 不會呼叫 Gemini API，完全不消耗您的免費額度。
 */
function autoOrganizeGmailWithGemini() {
  // 1. 初始化統計變數
  let successCount = 0;
  let failureCount = 0;
  let highUrgencyCount = 0;
  let mediumUrgencyCount = 0;
  let lowUrgencyCount = 0;
  let categoryStats = {};
  let minDate = null;
  let maxDate = null;
  let runSuccess = "Y";
  let executionError = "";
  const executionTime = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd HH:mm");

  // 從安全屬性中取得您的 Gemini API 金鑰
  const apiKey = PropertiesService.getScriptProperties().getProperty(GEMINI_API_KEY_PROPERTY);
  if (!apiKey) {
    Logger.log("Error: GEMINI_API_KEY is not set in script properties.");
    return;
  }

  try {
    // 2. 搜尋未讀且未分類之信件 (擷取最多 50 封以利排序)
    let threads = GmailApp.search(GMAIL_SEARCH_QUERY, 0, 50);
    
    if (threads.length === 0) {
      Logger.log("No unread threads found.");
      return;
    }
    
    // 3. 如果設定為最舊郵件優先，則反轉搜尋結果陣列
    if (PROCESS_OLDEST_FIRST) {
      threads.reverse();
      Logger.log("Reversed search threads to process oldest first.");
    }
    
    // 截取設定的最大掃描處理數量
    threads = threads.slice(0, MAX_THREADS_TO_SCAN);
    
    Logger.log(`Processing ${threads.length} target thread(s) for classification...`);

    // 取得試算表工作表 (僅用於寫入分類日誌)
    let sheet;
    try {
      sheet = getOrCreateRulesSheet();
    } catch (sheetError) {
      Logger.log("Failed to initialize rules sheet: " + sheetError.toString());
    }

    // 4. 逐一處理郵件對話串
    threads.forEach((thread, index) => {
      // 緩衝呼叫避免 API 頻率限制
      if (index > 0) {
        Utilities.sleep(API_CALL_DELAY_MS);
      }
      
      try {
        const messages = thread.getMessages();
        if (messages.length === 0) return;
        
        const lastMessage = messages[messages.length - 1];
        const rawSender = lastMessage.getFrom();
        const senderEmail = extractCleanEmail(rawSender);
        const subject = lastMessage.getSubject();
        
        // 擷取信件主旨與部分內文
        const body = lastMessage.getPlainBody().substring(0, EMAIL_BODY_CHAR_LIMIT);
        
        Logger.log(`Scanning Email [${index + 1}/${threads.length}] from: ${senderEmail} | Subject: [${subject}]`);
        
        // 呼叫 API 判讀
        let category = null;
        let urgency = null;
        let refinedContent = "";
        
        try {
          const result = callGeminiApi(apiKey, senderEmail, subject, body);
          if (result && result.category && result.urgency) {
            category = result.category;
            urgency = result.urgency;
            refinedContent = result.refinedContent || "";
            
            // 累加統計
            successCount++;
            categoryStats[category] = (categoryStats[category] || 0) + 1;
            
            if (urgency === "高") highUrgencyCount++;
            else if (urgency === "中") mediumUrgencyCount++;
            else if (urgency === "低") lowUrgencyCount++;
            
            // 計算收件日期範圍
            const threadDate = thread.getLastMessageDate();
            if (!minDate || threadDate < minDate) minDate = threadDate;
            if (!maxDate || threadDate > maxDate) maxDate = threadDate;
          } else {
            failureCount++;
            Logger.log("API returned invalid schema content.");
            // 降級處理：設定為「未分類」，避免重複判讀失敗導致佇列卡死
            category = "未分類";
            urgency = "低";
            refinedContent = "API判讀失敗，降級為未分類";
          }
        } catch (apiError) {
          failureCount++;
          Logger.log("Failed to process API call for thread: " + apiError.toString());
          // 降級處理：設定為「未分類」，避免重複判讀失敗導致佇列卡死
          category = "未分類";
          urgency = "低";
          refinedContent = "API異常：" + apiError.toString();
        }
        
        // 將分類結果與資訊精煉記錄至試算表中
        if (category && sheet) {
          try {
            const searchQuery = `from:${senderEmail}`;
            const nowString = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd HH:mm:ss");
            const senderName = extractSenderName(rawSender);
            sheet.appendRow([senderEmail, senderName, category, urgency, refinedContent, searchQuery, nowString]);
            Logger.log(`Logged email classification details for: ${senderEmail}`);
          } catch (saveError) {
            Logger.log("Failed to write log to sheet: " + saveError.toString());
          }
        }
        
        // 執行分類標籤套用動作
        if (category) {
          Logger.log(`Applying action: ${category} (${urgency}) for Email: [${subject}]`);
          const labelName = "AI/" + category;
          let label = GmailApp.getUserLabelByName(labelName);
          if (!label) {
            label = GmailApp.createLabel(labelName);
          }
          thread.addLabel(label);
          
          // 同步移至對應的 Gmail 收件匣分頁中
          const tabLabelId = CATEGORY_TAB_MAPPING[category];
          if (tabLabelId) {
            moveThreadToGmailCategory(thread.getId(), tabLabelId);
          }
        }
      } catch (threadError) {
        failureCount++;
        Logger.log(`Error processing thread at index ${index}: ` + threadError.toString());
      }
    });
    Logger.log("All unread emails processed!");
    
  } catch (error) {
    runSuccess = "N";
    executionError = error.toString();
    Logger.log("Exception occurred during main process: " + executionError);
  } finally {
    // 5. 確保在執行結束時，必定寫入執行統計日誌
    try {
      writeExecutionLog(executionTime, minDate, maxDate, successCount, failureCount, highUrgencyCount, mediumUrgencyCount, lowUrgencyCount, categoryStats, runSuccess, executionError);
    } catch (logError) {
      Logger.log("Fatal: Failed to write execution log sheet: " + logError.toString());
    }
  }
}

/**
 * 一次性歷史信件歸類工具。
 * 掃描所有歷史已歸類標籤 (AI/*) 的信件，並將其自動同步移至對應的 Gmail 分頁中。
 * 此執行完全不需呼叫 Gemini API。
 */
function syncExistingLabeledThreadsToCategories() {
  Logger.log("Starting historical email category migration...");
  try {
    for (const category in CATEGORY_TAB_MAPPING) {
      const tabLabelId = CATEGORY_TAB_MAPPING[category];
      const labelName = "AI/" + category;
      const label = GmailApp.getUserLabelByName(labelName);
      if (!label) continue;
      
      try {
        // 擷取前 100 封信（可根據需要重複執行以消化更大信量）
        const threads = label.getThreads(0, 100);
        Logger.log(`Found ${threads.length} threads labeled with '${labelName}'. Moving to ${tabLabelId}...`);
        
        threads.forEach((thread, index) => {
          if (index > 0) {
            Utilities.sleep(150); // 防範 API 頻率過載
          }
          moveThreadToGmailCategory(thread.getId(), tabLabelId);
        });
      } catch (labelError) {
        Logger.log(`Error processing label '${labelName}': ` + labelError.toString());
      }
    }
    Logger.log("Historical email category migration completed!");
  } catch (globalError) {
    Logger.log("Fatal error during historical email category migration: " + globalError.toString());
  }
}

// 核心函式：傳送資料給 Gemini API 並強制要求 JSON 結構
function callGeminiApi(apiKey, sender, subject, body) {
  // 使用最新的 2.5 Flash 模型，兼具速度與準確度
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;
  
  const promptText = `您是一位專業的智慧郵件分類秘書。請詳細分析以下郵件的寄件者、標題與內文，並依據分類規範決定其類別與緊急度。同時，請精煉該信件的關鍵核心內容。

【處理步驟指引 (Chain of Thought)】
1. **識別寄件主體**：判斷寄件者是何種平台或組織（如：LinkedIn、銀行、蝦皮、一般聯絡人）。
2. **區分受眾屬性**：分析此郵件是「僅針對收件人個人的互動/通知」（如私訊、面試邀請、個人交易、帳戶警報），或是「批次群發的非即時摘要/推廣」（如職缺週報、動態摘要、折價券廣告）。
3. **匹配分類與緊急度**：依據以下規範進行分類與緊急度評估。
4. **資訊提煉**：精煉出 20 字以內之郵件大意（去除一切無關語氣助詞，僅保留關鍵資訊與數據）。

【分類類別規範】
1. 「工作」：專屬個人的商務溝通、工作任務協作通知、求職互動信件（如：104人力銀行面試邀請）、社群平台個人對話（如：LinkedIn 專屬私訊/聯絡人信件）。
   *注意*：必須是針對收件者個人的互動或行動信件。若為群發的職缺電子報或動態摘要，必須分類為「社群通知」或「廣告行銷」。
2. 「財務帳單」：銀行交易明細、電子發票、帳單繳費通知、收據憑證、信用卡消費通知。
3. 「個人消費」：線上購物訂單確認、出貨/送達通知、外送平台明細、線下實體店面消費發票。
4. 「系統通知」：自動化系統警報、帳號啟用信、安全性驗證碼 (OTP)。
5. 「登入成功通知」：各家銀行或網站服務發送之安全「登入成功」確認信。
6. 「廣告行銷」：電子報、促銷廣告、折價券、產品推廣信。
7. 「社群通知」：社群平台群發的推廣或動態摘要信（如：LinkedIn 職缺推薦週報、Facebook 動態摘要）。
8. 「個人隱私」：親友的個人來信、私人旅遊訂房/機票確認信。
9. 「Netflix」：Netflix（含 @account.netflix.com 或 netflix.com 域名）發送之所有信件，例如：電子發票收據、帳戶安全提示、推薦觀看片單。

【緊急度評判規範】
- 「高」：需要即時關注或動作之信件。例如：驗證碼 (OTP)、登入異常安全警報、信用卡消費疑慮、急需處理的工作阻礙。
- 「中」：有時效性但無須立刻處理之信件。例如：幾天內到期的繳費帳單、工作會議預約、待辦任務。
- 「低」：單純資訊告知或不具時效性之信件。例如：廣告行銷促銷、登入成功通知、社群動態提醒。

【範例對照指引 (Few-Shot Examples)】
- *範例 1 (工作個人私訊)*：
  - 寄件者：\`LinkedIn <messages-noreply@linkedin.com>\`，標題：\`王大明傳送了訊息給您\`，內文：\`嗨，我看到您的履歷，想跟您聊聊...\`
  - 判定結果：\`category: "工作"\`, \`urgency: "中"\`, \`refinedContent: "LinkedIn私訊-王大明:想聊聊履歷"\`
- *範例 2 (社群群發週報)*：
  - 寄件者：\`LinkedIn <jobs-listings@linkedin.com>\`，標題：\`王大明，這些是適合您的職缺\`，內文：\`這週有 15 個符合您軟體工程師背景的新職缺...\`
  - 判定結果：\`category: "社群通知"\`, \`urgency: "低"\`, \`refinedContent: "LinkedIn-軟體工程師職缺推薦週報"\`
- *範例 3 (個人消費訂單)*：
  - 寄件者：\`Shopee <info@shopee.tw>\`，標題：\`訂單成立通知\`，內文：\`感謝您的消費，訂單編號 123456 已成立，消費金額 NT$ 500 元...\`
  - 判定結果：\`category: "個人消費"\`, \`urgency: "低"\`, \`refinedContent: "蝦皮購物-訂單成立-金額NT$500"\`
- *範例 4 (登入成功通知)*：
  - 寄件者：\`kgi@kgibank.com.tw\`，標題：\`網路銀行登入成功通知\`，內文：\`您於 2026-06-11 12:00 成功登入網路銀行，若非本人請聯絡客服...\`
  - 判定結果：\`category: "登入成功通知"\`, \`urgency: "低"\`, \`refinedContent: "凱基銀行-登入成功提醒"\`
- *範例 5 (系統高防護通知)*：
  - 寄件者：\`service@shopee.tw\`，標題：\`帳號變更驗證碼\`，內文：\`您的驗證碼為 987654，請於 5 分鐘內輸入完畢。\`
  - 判定結果：\`category: "系統通知"\`, \`urgency: "高"\`, \`refinedContent: "蝦皮購物-驗證碼:987654"\`
- *範例 6 (Netflix 登入驗證碼)*：
  - 寄件者：\`info@account.netflix.com\`，標題：\`Netflix：您的登入碼\`，內文：\`您的登入碼為 123456，請在 15 分鐘內輸入...\`
  - 判定結果：\`category: "Netflix"\`, \`urgency: "高"\`, \`refinedContent: "Netflix-登入碼:123456"\`
- *範例 7 (Netflix 同戶裝置確認)*：
  - 寄件者：\`info@account.netflix.com\`，標題：\`確認信：您已確認Netflix 同戶裝置\`，內文：\`您的電視已設定為此帳號的同戶裝置之一...\`
  - 判定結果：\`category: "Netflix"\`, \`urgency: "中"\`, \`refinedContent: "Netflix-同戶裝置已確認"\`

待分析郵件內容：
---
寄件者：${sender}
標題：${subject}
內文：${body}
---
請嚴格依據規定的 JSON Schema 結構輸出分析結果。`;

  // 設定 API 請求內容與強制的 Schema 結構
  const payload = {
    "contents": [{
      "parts": [{ "text": promptText }]
    }],
    "generationConfig": {
      "responseMimeType": "application/json", // 強制輸出 JSON 格式
      "responseSchema": {
        "type": "OBJECT",
        "properties": {
          "category": {
            "type": "STRING",
            "enum": ["工作", "財務帳單", "個人消費", "系統通知", "登入成功通知", "廣告行銷", "社群通知", "個人隱私", "Netflix"]
          },
          "urgency": {
            "type": "STRING",
            "enum": ["高", "中", "低"]
          },
          "refinedContent": {
            "type": "STRING"
          }
        },
        "required": ["category", "urgency", "refinedContent"]
      }
    }
  };

  const options = {
    "method": "post",
    "contentType": "application/json",
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };

  try {
    const response = UrlFetchApp.fetch(url, options);
    const responseText = response.getContentText();
    
    if (response.getResponseCode() === 200) {
      const json = JSON.parse(responseText);
      if (json && json.candidates && json.candidates[0] && json.candidates[0].content && json.candidates[0].content.parts && json.candidates[0].content.parts[0]) {
        const contentText = json.candidates[0].content.parts[0].text;
        try {
          return JSON.parse(contentText);
        } catch (parseError) {
          Logger.log("Failed to parse Gemini JSON response content: " + parseError.toString());
          return null;
        }
      } else {
        Logger.log("Unexpected Gemini API response structure: " + responseText);
        return null;
      }
    } else {
      Logger.log("Gemini API Error: " + responseText);
      return null;
    }
  } catch (e) {
    Logger.log("Exception occurred during API call: " + e.toString());
    return null;
  }
}

/**
 * 擷取乾淨的電子信箱地址 (小寫)
 * @param {string} emailString 原始信件地址字串
 * @return {string} 乾淨的信箱地址
 */
function extractCleanEmail(emailString) {
  if (!emailString) return "";
  const match = emailString.match(/<([^>]+)>/);
  if (match) {
    return match[1].trim().toLowerCase();
  }
  return emailString.trim().toLowerCase();
}

/**
 * 美化試算表排版外觀並設定緊急度條件格式化規則
 * @param {Sheet} sheet Google Sheets 工作表物件
 */
function formatSheetAesthetics(sheet) {
  // 1. 設定欄位寬度防止內容遮擋
  sheet.setColumnWidth(1, 240); // 電子信箱
  sheet.setColumnWidth(2, 160); // 寄件者名稱
  sheet.setColumnWidth(3, 110); // 類別
  sheet.setColumnWidth(4, 90);  // 緊急度
  sheet.setColumnWidth(5, 280); // AI 精煉內容
  sheet.setColumnWidth(6, 200); // Gmail 搜尋字串
  sheet.setColumnWidth(7, 160); // 更新時間
  
  // 2. 套用 A1:G1000 之交替背景色彩 (斑馬線)
  const fullRange = sheet.getRange("A1:G1000");
  fullRange.clearFormat(); // 清除舊格式
  
  // 清理現存的所有交替背景設定 (Bandings) 避免衝突
  const bandings = sheet.getBandings();
  bandings.forEach(banding => banding.remove());
  
  fullRange.setAlternatingRowColors(
    "#FFFFFF", // 奇數行
    "#F7FAFC", // 偶數行
    "#2D3748"  // 標題行
  );
  
  // 3. 設定標題列樣式 ( setAlternatingRowColors 會重製背景，需再將標題文字改為純白粗體)
